          <span class="cred-number" data-target="4">0</span>
          <span class="cred-label">rail-type variants designed</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── CTA ─── -->
  <div class="section-divider"></div>
  <section class="section cta-section" id="early-access">
    <div class="shape shape-circle cs1" aria-hidden="true"></div>
    <div class="shape shape-plus cs2" aria-hidden="true"></div>
    <div class="shape shape-line cs3" aria-hidden="true"></div>
    <div class="shape shape-ring cs4" aria-hidden="true"></div>
    <div class="container">
      <div class="reveal">
        <h2>Be the first to<br>try EasyGlide.</h2>
        <p class="cta-sub">Sign up for early access. We'll let you know when prototypes are ready.</p>

        <div class="cta-form-wrap">
          <div class="cta-form-glow" aria-hidden="true"></div>
          <form class="cta-form" action="https://formspree.io/f/placeholder" method="POST">
            <input type="email" name="email" placeholder="Your email address" required autocomplete="email" aria-label="Email address">
            <button type="submit">Notify Me</button>
          </form>
        </div>

        <p class="cta-fine">No spam. Just one email when we're ready.</p>
      </div>
    </div>
  </section>

  <!-- ─── FOOTER ─── -->
  <footer>
    <div class="footer-grid" aria-hidden="true"><span></span><span></span><span></span><span></span></div>
    <div class="container">
      <a href="#" class="back-to-top">
        <span class="top-arrow"></span>
        Back to top
      </a>
      <p class="footer-brand">EasyGlide — A GleitFix product &ensp;&middot;&ensp; Designed in Switzerland &ensp;&middot;&ensp; &copy; 2026 GleitFix</p>
    </div>
  </footer>


  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>
  <script>
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    // ── Loader ──
    const loader = document.querySelector('.loader');
    if (!prefersReducedMotion && loader) {
      setTimeout(() => {
        loader.style.transition = 'opacity 0.6s ease, visibility 0.6s ease';
        loader.style.opacity = '0';
        loader.style.visibility = 'hidden';
        document.body.classList.remove('loading');
        startAnimations();
      }, 1600);
    } else {
      if (loader) loader.style.display = 'none';
      document.body.classList.remove('loading');
      if (!prefersReducedMotion) startAnimations();
    }

    function startAnimations() {
      gsap.registerPlugin(ScrollTrigger);

      // ── Cursor glow ──
      const glow = document.querySelector('.cursor-glow');
      let gX = 0, gY = 0, cX = -500, cY = -500;
      document.addEventListener('mousemove', (e) => { cX = e.clientX; cY = e.clientY; });
      (function moveGlow() {
        gX += (cX - gX) * 0.06;
        gY += (cY - gY) * 0.06;
        glow.style.left = gX + 'px';
        glow.style.top = gY + 'px';
        requestAnimationFrame(moveGlow);
      })();

      // ── Ambient orbs drift ──
      gsap.to('.orb-1', { x: 30, y: -20, duration: 12, repeat: -1, yoyo: true, ease: 'sine.inOut' });
      gsap.to('.orb-2', { x: -25, y: 15, duration: 10, repeat: -1, yoyo: true, ease: 'sine.inOut' });

      // ── Scroll progress ──
      const progressBar = document.querySelector('.scroll-progress');
      ScrollTrigger.create({
        trigger: document.body,
        start: 'top top',
        end: 'bottom bottom',
        onUpdate: (self) => { progressBar.style.width = (self.progress * 100) + '%'; }
      });

      // ── Nav ──
      ScrollTrigger.create({
        start: 'top -50',
        onUpdate: (self) => { document.querySelector('nav').classList.toggle('scrolled', self.progress > 0); }
      });

      // ── Aluminum rail parallax ──
      const railEl = document.querySelector('.rail-parallax');
      gsap.to(railEl, {
        xPercent: -30,
        ease: 'none',
        scrollTrigger: {
          trigger: document.body,
          start: 'top top',
          end: 'bottom bottom',
          scrub: 0.8,
          onUpdate: (self) => {
            const show = self.progress > 0.08 && self.progress < 0.85;
            railEl.classList.toggle('visible', show);
          }
        }
      });

      // ── Hero entrance ──
      const heroTL = gsap.timeline({ defaults: { ease: 'power4.out' }, delay: 0.2 });
      heroTL
        .from('.hero-label-inner', { y: '100%', duration: 0.9 })
        .from('.hero-line .line-inner', { y: '115%', rotation: 3, stagger: 0.12, duration: 1.3 }, '-=0.5')
        .from('.hero-sub', { y: 30, opacity: 0, duration: 1 }, '-=0.5')
        .from('.btn-magnetic', { y: 20, opacity: 0, duration: 0.8 }, '-=0.5')
        .from('.hero-scroll', { opacity: 0, duration: 1.5 }, '-=0.3');

      // ── Hero shapes parallax ──
      gsap.utils.toArray('.hero .shape').forEach((shape, i) => {
        gsap.to(shape, {
          y: [55, -70, 35, -55, 45, -25, 60, 40][i % 8],
          rotation: [10, -7, 4, -12, 8, -4, 6, -9][i % 8],
          ease: 'none',
          scrollTrigger: { trigger: '.hero', start: 'top top', end: 'bottom top', scrub: 0.6 }
        });
      });

      // ── Hero text parallax fade ──
      gsap.to('.hero-lines', {
        y: -80, opacity: 0, ease: 'none',
        scrollTrigger: { trigger: '.hero', start: '55% top', end: 'bottom top', scrub: true }
      });

      gsap.to('.hero-sub', {
        y: -40, opacity: 0, ease: 'none',
        scrollTrigger: { trigger: '.hero', start: '65% top', end: 'bottom top', scrub: true }
      });

      // ── Section dividers ──
      gsap.utils.toArray('.section-divider').forEach((d) => {
        ScrollTrigger.create({
          trigger: d, start: 'top 92%',
          onEnter: () => d.classList.add('swept'),
          once: true
        });
      });

      // ── Reveal ──
      gsap.utils.toArray('.reveal').forEach((el) => {
        gsap.to(el, {
          y: 0, opacity: 1, duration: 1.2, ease: 'power3.out',
          scrollTrigger: { trigger: el, start: 'top 88%', toggleActions: 'play none none none' }
        });
      });

      // ── Staggered children ──
      gsap.utils.toArray('.reveal-children').forEach((parent) => {
        gsap.to(parent.children, {
          y: 0, opacity: 1, stagger: 0.1, duration: 1, ease: 'power3.out',
          scrollTrigger: { trigger: parent, start: 'top 85%', toggleActions: 'play none none none' }
        });
      });

      // ── Stat counters ──
      gsap.utils.toArray('[data-target]').forEach((el) => {
        const target = parseInt(el.dataset.target);
        let suffix = '';
        if (el.classList.contains('cred-number')) {
          const lbl = el.nextElementSibling;
          if (lbl && lbl.textContent.includes('confirmed')) suffix = '%';
          else if (lbl && lbl.textContent.includes('interviews')) suffix = '+';
        }
        const obj = { val: 0 };
        gsap.to(obj, {
          val: target, duration: 2.4, ease: 'power2.out',
          scrollTrigger: { trigger: el, start: 'top 88%', toggleActions: 'play none none none' },
          onUpdate: () => { el.textContent = Math.round(obj.val) + suffix; }
        });
      });

      // ── Image wipe reveals ──
      gsap.utils.toArray('.img-wipe').forEach((img, i) => {
        ScrollTrigger.create({
          trigger: img, start: 'top 85%',
          onEnter: () => {
            setTimeout(() => img.classList.add('revealed'), i * 150);
          },
          once: true
        });
      });

      // ── Rail profile draw-on ──
      gsap.utils.toArray('.rail-profile').forEach((card) => {
        ScrollTrigger.create({
          trigger: card, start: 'top 85%',
          onEnter: () => card.classList.add('drawn'),
          once: true
        });
      });

      // ── Parallax: problem shapes ──
      gsap.utils.toArray('.problem .shape').forEach((s, i) => {
        gsap.to(s, {
          y: [35, -45][i % 2], rotation: [6, -5][i % 2], ease: 'none',
          scrollTrigger: { trigger: '.problem', start: 'top bottom', end: 'bottom top', scrub: 0.5 }
        });
      });

      // ── Parallax: CTA shapes ──
      gsap.utils.toArray('.cta-section .shape').forEach((s, i) => {
        gsap.to(s, {
          y: [45, -35, 25, -40][i % 4], rotation: [8, -10, 5, -7][i % 4], ease: 'none',
          scrollTrigger: { trigger: '.cta-section', start: 'top bottom', end: 'bottom top', scrub: 0.5 }
        });
      });

      // ── Horizontal scroll (desktop) ──
      if (window.innerWidth >= 768) {
        const track = document.querySelector('.how-track');
        const dots = document.querySelector('.how-dots');
        const dotEls = document.querySelectorAll('.how-dot');

        const howScroll = gsap.to(track, {
          xPercent: -66.666,
          ease: 'none',
          scrollTrigger: {
            trigger: '.how-wrapper',
            pin: true,
            scrub: 1,
            end: () => '+=' + (track.scrollWidth - window.innerWidth),
            invalidateOnRefresh: true,
            onEnter: () => dots.classList.add('visible'),
            onLeave: () => dots.classList.remove('visible'),
            onEnterBack: () => dots.classList.add('visible'),
            onLeaveBack: () => dots.classList.remove('visible'),
            onUpdate: (self) => {
              const step = Math.min(2, Math.floor(self.progress * 3));
              dotEls.forEach((d, i) => d.classList.toggle('active', i === step));
            }
          }
        });
      }

      // ── Magnetic button ──
      const magnetic = document.querySelector('.btn-magnetic');
      if (magnetic) {
        const btn = magnetic.querySelector('.btn-primary');
        magnetic.addEventListener('mousemove', (e) => {
          const rect = magnetic.getBoundingClientRect();
          const x = e.clientX - rect.left - rect.width / 2;
          const y = e.clientY - rect.top - rect.height / 2;
          gsap.to(btn, { x: x * 0.25, y: y * 0.25, duration: 0.4, ease: 'power2.out' });
        });
        magnetic.addEventListener('mouseleave', () => {
          gsap.to(btn, { x: 0, y: 0, duration: 0.7, ease: 'elastic.out(1, 0.35)' });
        });
      }
    }

    // ── Reduced motion fallback ──
    if (prefersReducedMotion) {
      document.querySelectorAll('.reveal').forEach(el => { el.style.opacity = '1'; el.style.transform = 'none'; });
      document.querySelectorAll('.reveal-children > *').forEach(el => { el.style.opacity = '1'; el.style.transform = 'none'; });
      document.querySelectorAll('.rail-profile').forEach(el => el.classList.add('drawn'));
      document.querySelectorAll('.img-wipe').forEach(el => el.classList.add('revealed'));
      document.querySelectorAll('[data-target]').forEach(el => {
        let s = '';
        if (el.classList.contains('cred-number')) {
          const l = el.nextElementSibling;
          if (l && l.textContent.includes('confirmed')) s = '%';
          else if (l && l.textContent.includes('interviews')) s = '+';
        }
        el.textContent = el.dataset.target + s;
      });
    }

    // ── Smooth scroll ──
    document.querySelectorAll('a[href^="#"]').forEach(link => {
      link.addEventListener('click', (e) => {
        const t = document.querySelector(link.getAttribute('href'));
        if (t) { e.preventDefault(); t.scrollIntoView({ behavior: 'smooth', block: 'start' }); }
      });
    });
  </script>
</body>
</html>
