<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>EasyGlide — Load once. Slide in. Done.</title>
  <meta name="description" content="The first universal curtain-loading adapter. Load all gliders at table height, snap onto any recessed rail, slide everything in. Designed in Switzerland.">
  <meta property="og:title" content="EasyGlide — Load once. Slide in. Done.">
  <meta property="og:description" content="The first universal curtain-loading adapter. Designed in Switzerland.">
  <meta property="og:image" content="images/og-image.png">
  <meta property="og:type" content="website">
  <meta name="twitter:card" content="summary_large_image">
  <link rel="icon" href="images/favicon.ico">
  <link rel="apple-touch-icon" href="images/apple-touch-icon.png">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,700;1,9..40,400&family=DM+Serif+Display&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    :root {
      --bg: #0A0A0A;
      --surface: #111111;
      --text: #F0EDE6;
      --text-dim: #A8A89E;
      --text-secondary: #6B6B63;
      --teal: #4A8C7B;
      --teal-dim: rgba(74,140,123,0.08);
      --amber: #D4903A;
      --amber-bright: #E8A54A;
      --amber-dim: rgba(212,144,58,0.1);
      --border: #1A1A1A;
      --font-display: 'DM Serif Display', Georgia, serif;
      --font-body: 'DM Sans', 'Helvetica Neue', Arial, sans-serif;
    }

    html { -webkit-font-smoothing: antialiased; -moz-osx-font-smoothing: grayscale; }

    /* Custom scrollbar */
    ::-webkit-scrollbar { width: 6px; }
    ::-webkit-scrollbar-track { background: var(--bg); }
    ::-webkit-scrollbar-thumb { background: #2A2A2A; border-radius: 3px; }
    ::-webkit-scrollbar-thumb:hover { background: #3A3A3A; }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: var(--font-body);
      font-size: 18px;
      line-height: 1.6;
      overflow-x: hidden;
    }

    body.loading { overflow: hidden; }

    ::selection { background: var(--amber); color: var(--bg); }
    a { color: inherit; text-decoration: none; }
    img { max-width: 100%; display: block; }

    /* ─── LOADER ─── */
    .loader {
      position: fixed;
      inset: 0;
      z-index: 9000;
      background: var(--bg);
      display: flex;
      align-items: center;
      justify-content: center;
      flex-direction: column;
      gap: 1.5rem;
    }

    .loader-text {
      font-family: var(--font-display);
      font-size: 1.2rem;
      color: var(--text-secondary);
      letter-spacing: 0.1em;
    }

    .loader-bar {
      width: 120px;
      height: 1px;
      background: var(--border);
      position: relative;
      overflow: hidden;
    }

    .loader-bar::after {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      height: 100%;
      width: 0%;
      background: var(--amber);
      animation: loaderFill 1.4s cubic-bezier(0.4, 0, 0.2, 1) forwards;
    }

    @keyframes loaderFill {
      0% { width: 0%; }
      100% { width: 100%; }
    }

    /* ─── SCROLL PROGRESS ─── */
    .scroll-progress {
      position: fixed;
      top: 0;
      left: 0;
      height: 1px;
      width: 0%;
      background: linear-gradient(90deg, var(--amber), var(--amber-bright));
      z-index: 200;
    }

    /* ─── GRAIN ─── */
    .grain {
      position: fixed;
      inset: 0;
      z-index: 8000;
      pointer-events: none;
      opacity: 0.03;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.8' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
      background-size: 200px;
    }

    /* ─── AMBIENT ORBS ─── */
    .orb {
      position: fixed;
      border-radius: 50%;
      pointer-events: none;
      z-index: 0;
      will-change: transform;
    }

    .orb-1 {
      width: 500px;
      height: 500px;
      background: radial-gradient(circle, var(--amber-dim) 0%, transparent 70%);
      top: 5%;
      left: -10%;
      opacity: 0.5;
    }

    .orb-2 {
      width: 450px;
      height: 450px;
      background: radial-gradient(circle, var(--amber-dim) 0%, transparent 70%);
      bottom: 10%;
      right: -12%;
      opacity: 0.5;
    }

    /* ─── CURSOR GLOW ─── */
    .cursor-glow {
      position: fixed;
      width: 400px;
      height: 400px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(196,136,58,0.03) 0%, transparent 70%);
      pointer-events: none;
      z-index: 1;
      transform: translate(-50%, -50%);
    }

    /* ─── LABEL ─── */
    .label {
      font-family: var(--font-body);
      font-size: 0.65rem;
      font-weight: 500;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: var(--text-secondary);
      margin-bottom: 2rem;
      display: flex;
      align-items: center;
      gap: 1rem;
    }

    .label::before {
      content: '';
      width: 20px;
      height: 1px;
      background: var(--amber);
      flex-shrink: 0;
    }

    .container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 clamp(1.5rem, 5vw, 4rem);
      position: relative;
      z-index: 2;
    }

    /* ─── NAV ─── */
    nav {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: 100;
      padding: 1.25rem 0;
      transition: background 0.6s ease, padding 0.6s ease, border-color 0.6s ease;
      border-bottom: 1px solid transparent;
    }

    nav.scrolled {
      background: rgba(10, 10, 10, 0.92);
      backdrop-filter: blur(24px);
      -webkit-backdrop-filter: blur(24px);
      padding: 0.75rem 0;
      border-bottom-color: rgba(255,255,255,0.03);
    }

    nav .container { display: flex; justify-content: space-between; align-items: center; }
    nav .logo img { height: 30px; width: auto; opacity: 0.85; transition: opacity 0.3s; }
    nav .logo:hover img { opacity: 1; }

    .nav-cta {
      font-size: 0.75rem;
      font-weight: 500;
      letter-spacing: 0.08em;
      padding: 0.5rem 1.3rem;
      border: 1px solid rgba(196,136,58,0.35);
      color: var(--amber);
      border-radius: 100px;
      transition: all 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94);
      cursor: pointer;
      position: relative;
      overflow: hidden;
    }

    .nav-cta::before {
      content: '';
      position: absolute;
      inset: 0;
      background: var(--amber);
      transform: scaleX(0);
      transform-origin: left;
      transition: transform 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94);
      z-index: -1;
      border-radius: 100px;
    }

    .nav-cta:hover { color: var(--bg); border-color: var(--amber); }
    .nav-cta:hover::before { transform: scaleX(1); }

    /* ─── SHAPES ─── */
    .shape { position: absolute; pointer-events: none; will-change: transform; }
    .shape-circle { border-radius: 50%; border: 1px solid currentColor; }
    .shape-dot { border-radius: 50%; background: currentColor; }
    .shape-ring { border-radius: 50%; border: 1px solid currentColor; }
    .shape-plus { position: relative; }
    .shape-plus::before, .shape-plus::after {
      content: ''; position: absolute; top: 50%; left: 50%; background: currentColor;
    }
    .shape-plus::before { width: 1px; height: 100%; transform: translate(-50%, -50%); }
    .shape-plus::after { width: 100%; height: 1px; transform: translate(-50%, -50%); }
    .shape-line { height: 1px; background: currentColor; }

    /* ─── HERO ─── */
    .hero {
      position: relative;
      min-height: 100vh;
      min-height: 100dvh;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      text-align: center;
      padding: 6rem 2rem 4rem;
      overflow: hidden;
    }

    .hero-label {
      font-family: var(--font-body);
      font-size: 0.7rem;
      font-weight: 400;
      letter-spacing: 0.45em;
      text-transform: uppercase;
      color: var(--text-secondary);
      margin-bottom: 2.5rem;
      overflow: hidden;
    }

    .hero-label-inner { display: inline-block; }

    .hero-lines { margin-bottom: 3rem; }

    .hero-line {
      font-family: var(--font-display);
      font-size: clamp(3.5rem, 9vw, 10rem);
      line-height: 1.08;
      display: block;
      overflow: hidden;
    }

    .hero-line .line-inner { display: block; will-change: transform; }

    .hero-line:nth-child(1) { color: var(--text); }
    .hero-line:nth-child(2) { color: var(--amber); text-shadow: 0 0 80px rgba(212,144,58,0.15); }
    .hero-line:nth-child(3) { color: var(--amber-bright); text-shadow: 0 0 60px rgba(232,165,74,0.12); }

    .hero-sub {
      font-size: clamp(0.9rem, 1.6vw, 1.05rem);
      color: var(--text-secondary);
      max-width: 400px;
      margin-bottom: 3rem;
      line-height: 1.75;
      font-weight: 300;
      letter-spacing: 0.015em;
    }

    /* Magnetic button */
    .btn-magnetic { position: relative; display: inline-flex; }

    .btn-primary {
      display: inline-flex;
      align-items: center;
      gap: 0.6rem;
      font-family: var(--font-body);
      font-size: 0.9rem;
      font-weight: 500;
      letter-spacing: 0.03em;
      padding: 0.9rem 2.2rem;
      background: var(--amber);
      color: var(--bg);
      border: none;
      border-radius: 100px;
      cursor: pointer;
      transition: box-shadow 0.5s ease;
      text-decoration: none;
      position: relative;
      overflow: hidden;
    }

    .btn-primary::after {
      content: '';
      position: absolute;
      inset: 0;
      border-radius: 100px;
      background: linear-gradient(135deg, rgba(255,255,255,0.18) 0%, transparent 50%);
      opacity: 0;
      transition: opacity 0.5s ease;
    }

    .btn-primary:hover::after { opacity: 1; }
    .btn-primary:hover { box-shadow: 0 0 50px rgba(196,136,58,0.2), 0 12px 32px rgba(196,136,58,0.15); }

    .btn-primary .arrow {
      transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
      display: inline-block;
    }

    .btn-primary:hover .arrow { transform: translateX(5px); }

    .hero-scroll {
      position: absolute;
      bottom: 2rem;
      font-size: 0.6rem;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: var(--text-secondary);
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.75rem;
      opacity: 0.4;
    }

    .scroll-arrow {
      width: 1px;
      height: 44px;
      position: relative;
      overflow: hidden;
    }

    .scroll-arrow::after {
      content: '';
      position: absolute;
      top: -100%;
      left: 0;
      width: 1px;
      height: 100%;
      background: linear-gradient(to bottom, transparent, var(--text-secondary));
      animation: scrollDown 2.2s ease-in-out infinite;
    }

    @keyframes scrollDown {
      0% { top: -100%; }
      100% { top: 100%; }
    }

    /* Hero shapes */
    .hero .s1 { top: 12%; left: 6%; width: 150px; height: 150px; color: var(--amber); opacity: 0.05; }
    .hero .s2 { top: 20%; right: 8%; width: 18px; height: 18px; color: var(--amber); opacity: 0.18; }
    .hero .s3 { bottom: 24%; left: 10%; width: 90px; color: var(--border); opacity: 0.18; }
    .hero .s4 { bottom: 30%; right: 9%; width: 90px; height: 90px; color: var(--amber); opacity: 0.04; }
    .hero .s5 { top: 36%; left: 3%; width: 12px; height: 12px; color: var(--amber-bright); opacity: 0.12; }
    .hero .s6 { top: 16%; left: 42%; width: 5px; height: 5px; color: var(--amber); opacity: 0.15; }
    .hero .s7 { bottom: 18%; right: 22%; width: 3px; height: 3px; color: var(--amber); opacity: 0.2; }
    .hero .s8 { top: 50%; right: 4%; width: 60px; color: var(--border); opacity: 0.1; }

    /* ─── SECTION ─── */
    .section {
      padding: clamp(7rem, 15vw, 13rem) 0;
      position: relative;
    }

    .section-divider {
      width: 100%;
      height: 1px;
      background: var(--border);
      position: relative;
      overflow: hidden;
    }

    .section-divider::after {
      content: '';
      position: absolute;
      top: 0; left: 0;
      width: 100%;
      height: 100%;
      background: linear-gradient(90deg, transparent, var(--amber), transparent);
      transform: scaleX(0);
      transform-origin: left;
    }

    .section-divider.swept::after {
      animation: divSweep 1.4s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards;
    }

    @keyframes divSweep {
      0% { transform: scaleX(0); opacity: 0.5; }
      100% { transform: scaleX(1); opacity: 0; }
    }

    /* ─── PROBLEM ─── */
    .problem { background: var(--bg); position: relative; overflow: hidden; }
    .problem-content { max-width: 640px; }

    .problem h2 {
      font-family: var(--font-display);
      font-size: clamp(2.5rem, 5.5vw, 5rem);
      line-height: 1.08;
      margin-bottom: 2.5rem;
    }

    .problem h2 em { font-style: normal; color: var(--amber); }

    .problem p {
      font-size: clamp(0.95rem, 1.5vw, 1.1rem);
      color: var(--text-dim);
      line-height: 1.9;
      margin-bottom: 1.25rem;
      font-weight: 300;
    }

    .problem .stat {
      display: inline-flex;
      align-items: baseline;
      gap: 0.75rem;
      margin-top: 3rem;
      padding-top: 2.5rem;
      border-top: 1px solid var(--border);
    }

    .problem .stat-number {
      font-family: var(--font-display);
      font-size: clamp(3.5rem, 6vw, 5rem);
      color: var(--amber);
      line-height: 1;
    }

    .problem .stat-label {
      font-size: 0.9rem;
      color: var(--text-secondary);
      font-weight: 300;
    }

    .problem .ps1 { top: 8%; right: 6%; width: 110px; height: 110px; color: var(--amber); opacity: 0.04; }
    .problem .ps2 { bottom: 12%; right: 12%; width: 16px; height: 16px; color: var(--amber); opacity: 0.08; }

    /* ─── HOW IT WORKS ─── */
    .how-wrapper { overflow: hidden; }
    .how-inner { position: relative; }

    .how-header { padding: clamp(7rem, 15vw, 13rem) 0 4rem; }

    .how-header h2 {
      font-family: var(--font-display);
      font-size: clamp(2.5rem, 5.5vw, 5rem);
      line-height: 1.08;
    }

    /* Step dots indicator */
    .how-dots {
      position: fixed;
      right: 2rem;
      top: 50%;
      transform: translateY(-50%);
      display: flex;
      flex-direction: column;
      gap: 12px;
      z-index: 50;
      opacity: 0;
      transition: opacity 0.5s ease;
    }

    .how-dots.visible { opacity: 1; }

    .how-dot {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: var(--text-secondary);
      opacity: 0.3;
      transition: all 0.4s ease;
    }

    .how-dot.active {
      opacity: 1;
      background: var(--amber);
      transform: scale(1.4);
    }

    .how-track { display: flex; width: 300%; }

    .how-step {
      width: 100vw;
      min-height: 70vh;
      display: flex;
      align-items: center;
      padding: 0 clamp(1.5rem, 5vw, 4rem);
      position: relative;
    }

    .how-step-inner {
      max-width: 1200px;
      margin: 0 auto;
      width: 100%;
      display: grid;
      grid-template-columns: auto 1fr;
      gap: clamp(2rem, 5vw, 5rem);
      align-items: center;
    }

    .step-number {
      font-family: var(--font-display);
      font-size: clamp(8rem, 18vw, 16rem);
      color: var(--amber);
      opacity: 0.06;
      line-height: 1;
      user-select: none;
    }

    .step-content h3 {
      font-family: var(--font-display);
      font-size: clamp(2rem, 4vw, 3.5rem);
      margin-bottom: 1.25rem;
      color: var(--amber);
    }

    .step-content p {
      font-size: clamp(0.95rem, 1.3vw, 1.05rem);
      color: var(--text-dim);
      line-height: 1.9;
      max-width: 440px;
      font-weight: 300;
    }

    .step-accent {
      position: absolute;
      bottom: 12%;
      right: 8%;
      width: 70px;
      height: 70px;
      border-radius: 50%;
      border: 1px solid var(--amber);
      opacity: 0.04;
    }

    .how-punchline { padding: 4rem 0 clamp(7rem, 15vw, 13rem); }

    .how-punchline p {
      font-family: var(--font-display);
      font-size: clamp(1.4rem, 2.8vw, 2.4rem);
      color: var(--text);
      max-width: 660px;
      line-height: 1.35;
    }

    .how-punchline em {
      font-style: normal;
      color: var(--amber);
      position: relative;
    }

    .how-punchline em::after {
      content: '';
      position: absolute;
      bottom: -2px;
      left: 0;
      width: 100%;
      height: 1px;
      background: linear-gradient(90deg, var(--amber), transparent);
      opacity: 0.4;
    }

    @media (max-width: 767px) {
      .how-track { flex-direction: column; width: 100%; }
      .how-step { width: 100%; min-height: auto; padding: 3rem clamp(1.5rem, 5vw, 4rem); }
      .how-step-inner { grid-template-columns: 1fr; gap: 0; }
      .step-number { font-size: 5rem; margin-bottom: -0.5rem; }
      .step-accent { display: none; }
      .how-dots { display: none; }
    }

    /* ─── AUDIENCE ─── */
    .audience { background: var(--surface); position: relative; overflow: hidden; }

    .audience h2 {
      font-family: var(--font-display);
      font-size: clamp(2rem, 4.5vw, 3.5rem);
      line-height: 1.15;
      margin-bottom: 4rem;
      max-width: 620px;
    }

    .audience-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; }

    @media (max-width: 767px) {
      .audience-grid { grid-template-columns: 1fr; }
    }

    .audience-card {
      padding: 2.5rem;
      border: 1px solid var(--border);
      border-radius: 16px;
      background: rgba(10,10,10,0.5);
      transition: border-color 0.6s ease, box-shadow 0.6s ease, transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
      position: relative;
      overflow: hidden;
    }

    .audience-card::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 1px;
      background: linear-gradient(90deg, transparent, var(--amber), transparent);
      opacity: 0;
      transition: opacity 0.6s ease;
    }

    .audience-card:hover {
      border-color: rgba(212,144,58,0.2);
      box-shadow: 0 12px 48px rgba(0,0,0,0.35), 0 0 0 1px rgba(212,144,58,0.06);
      transform: translateY(-6px);
    }

    .audience-card:hover::before { opacity: 0.4; }

    .audience-card .card-icon {
      width: 36px;
      height: 36px;
      border-radius: 10px;
      border: 1px solid rgba(212,144,58,0.2);
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 1.5rem;
      font-size: 0.85rem;
      color: var(--amber);
      transition: border-color 0.5s ease, background 0.5s ease;
    }

    .audience-card:hover .card-icon {
      border-color: rgba(212,144,58,0.4);
      background: rgba(212,144,58,0.06);
    }

    .audience-card .card-label {
      font-size: 0.6rem;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: var(--amber);
      font-weight: 500;
      margin-bottom: 1.25rem;
    }

    .audience-card h3 {
      font-family: var(--font-display);
      font-size: 1.35rem;
      margin-bottom: 1rem;
    }

    .audience-card p {
      font-size: 0.92rem;
      color: var(--text-dim);
      line-height: 1.8;
      font-weight: 300;
    }

    /* ─── DIFFERENTIATOR ─── */
    .differentiator { background: var(--bg); position: relative; overflow: hidden; }

    .differentiator h2 {
      font-family: var(--font-display);
      font-size: clamp(2.5rem, 5.5vw, 5rem);
      line-height: 1.08;
      margin-bottom: 1.5rem;
    }

    .diff-body {
      font-size: clamp(0.95rem, 1.3vw, 1.05rem);
      color: var(--text-dim);
      line-height: 1.9;
      max-width: 540px;
      margin-bottom: 5rem;
      font-weight: 300;
    }

    .rail-profiles { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }

    @media (max-width: 600px) {
      .rail-profiles { grid-template-columns: 1fr; max-width: 260px; }
    }

    .rail-profile {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 1.25rem;
      padding: 2rem 1.5rem;
      border: 1px solid var(--border);
      border-radius: 14px;
      background: var(--surface);
      transition: border-color 0.5s ease, transform 0.5s ease;
    }

    .rail-profile:hover { border-color: rgba(212,144,58,0.2); transform: translateY(-3px); }

    .rail-profile svg { width: 100%; max-width: 140px; height: auto; }

    .rail-profile .draw-path {
      stroke-dasharray: 800;
      stroke-dashoffset: 800;
      transition: stroke-dashoffset 1.8s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    }

    .rail-profile.drawn .draw-path { stroke-dashoffset: 0; }

    .rail-profile .glider-dot { opacity: 0; transition: opacity 0.6s ease 1.4s; }
    .rail-profile.drawn .glider-dot { opacity: 1; }

    .rail-profile span {
      font-size: 0.65rem;
